{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "./frontend/dist",
  "env": {
    "NODE_ENV": "production"
  },
  "includes": [
    "sample_test.csv",
    "sample_test_out.csv",
    "api/**"
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
